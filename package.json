{
  "name": "alquran",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1",
    "api:php": "php -S 127.0.0.1:8090 -t . router.php",
    "serve:prod": "php -S 0.0.0.0:8090 -t . router.php",
    "deploy:build": "npm run build",
    "talaqqi:chat": "npm run start --prefix server/talaqqi-chat",
    "talaqqi:chat:dev": "npm run dev --prefix server/talaqqi-chat",
    "talaqqi:chat:install": "npm install --prefix server/talaqqi-chat",
    "cms:export": "npx tsx scripts/cms-export.mjs",
    "db:install": "php api/install-mysql.php",
    "db:sync": "php api/sync-mysql.php",
    "db:sync:ulumul": "php api/sync-ulumul.php",
    "db:indexes": "php api/migrate-performance-indexes.php",
    "db:sync:sqlite": "php api/sync-mysql.php --from-sqlite",
    "build": "tsc -b && vite build",
    "build:apk": "npm run build && npx cap sync android",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:build": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:install:debug": "powershell -ExecutionPolicy Bypass -File scripts/android-install-debug.ps1",
    "android:test:login": "powershell -ExecutionPolicy Bypass -File scripts/test-google-oauth.ps1",
    "android:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease",
    "android:bundle": "npm run cap:sync && cd android && gradlew.bat bundleRelease",
    "android:sha1": "powershell -ExecutionPolicy Bypass -File scripts/android-sha1.ps1",
    "brand:assets": "powershell -ExecutionPolicy Bypass -File scripts/generate-brand-assets.ps1",
    "icons:remove-bg": "node scripts/remove-icon-background.mjs",
    "icons:remove-alquran-bg": "node scripts/remove-alquran-bg.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/core": "^7.2.0",
    "@react-oauth/google": "^0.13.5",
    "driver.js": "^1.4.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@capacitor/cli": "^7.2.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
