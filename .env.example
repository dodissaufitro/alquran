# --- Guru / koreksi rekaman Talaqqi (login Google) ---
# Email yang mendapat mode guru — pisahkan koma:
# VITE_TALAQQI_SUPER_ADMIN_EMAILS=anda@gmail.com

# --- Chat rekaman Talaqqi (server Node sendiri) ---
# 1. npm run talaqqi:chat:install   (sekali)
# 2. npm run talaqqi:chat           (terminal terpisah)
# 3. npm run dev
# Proxy Vite saat npm run dev (default: server Node port 3847)
# VITE_TALAQQI_PROXY_TARGET=http://127.0.0.1:3847
# VITE_LARAGON_PROXY_TARGET=http://alquran.test
# VITE_TALAQQI_API_BASE=/api/talaqqi
# VITE_TALAQQI_WS_URL=ws://localhost:5173/api/talaqqi/ws
#
# Alternatif PHP Laragon (tanpa server Node):
# VITE_TALAQQI_API_BASE=http://alquran.test/api/talaqqi

# --- Jurnal: login Google + langganan berbayar ---
# Buat OAuth Client ID di Google Cloud Console (tipe: Web application)
# Hanya Client ID yang dipakai di app React. Client Secret TIDAK dimasukkan ke .env frontend.
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web)
# → Authorized JavaScript origins (harus sama persis dengan URL di browser):
#   http://localhost:5173
#   http://127.0.0.1:5173
#   http://alquran.test
# Jika port 5173 penuh dan Vite pakai port lain, tambahkan juga mis. http://localhost:5174
#
# Untuk APK (Capacitor) WAJIB tambahkan juga:
#   Authorized JavaScript origins:
#     https://localhost
#     http://localhost
#   Authorized redirect URIs:
#     com.faithfulpath.alquran://oauth
# Login di Android membuka browser sistem (bukan popup di WebView).
# Simpan, tunggu 1–5 menit, lalu build ulang: npm run build && npm run cap:sync
#
# PENTING: VITE_GOOGLE_CLIENT_ID harus ada saat `npm run build` (file .env tidak ikut git).

# API langganan (default: /api/subscription lewat proxy Vite)
# Terminal 1: npm run api:php     → PHP di http://127.0.0.1:8090
# Terminal 2: npm run dev
# VITE_LARAGON_PROXY_TARGET=http://127.0.0.1:8090
# Jika Laragon Apache aktif, bisa: VITE_LARAGON_PROXY_TARGET=http://alquran.test
# VITE_SUBSCRIPTION_API_BASE=http://alquran.test/api/subscription

# Kunci demo pembayaran (harus sama dengan SUBSCRIPTION_DEMO_SECRET di server PHP)
# VITE_SUBSCRIPTION_DEMO_KEY=faithfulpath-jurnal-demo-2026

# Di server PHP (Laragon), set di api/subscription/config.local.php:
# SUBSCRIPTION_DEMO_SECRET=faithfulpath-jurnal-demo-2026
#
# Xendit (disarankan untuk jurnal & buku — redirect ke halaman Xendit)
# Set di api/subscription/config.local.php:
#   XENDIT_SECRET_KEY=xnd_development_...
#   XENDIT_WEBHOOK_TOKEN=...
#   SUBSCRIPTION_REDIRECT_BASE_URL=http://localhost:5173   (npm run dev)
#   SUBSCRIPTION_REDIRECT_BASE_URL=https://localhost       (APK Capacitor)
# Webhook: https://domain-anda.com/api/subscription/notification.php
# Redirect URI di Google/Xendit dashboard: com.faithfulpath.alquran://oauth (login)
# Authorized redirect (Xendit invoice): https://localhost/?fp_payment=success

# QRIS Midtrans (production / sandbox, jika Xendit tidak di-set):
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
# MIDTRANS_IS_PRODUCTION=0
# Webhook URL di dashboard Midtrans:
#   https://alquran.test/api/subscription/notification.php
#
# --- CMS (panel admin konten) ---
# Panel: http://localhost:5173/admin.html
# Login default: admin / faithfulpath-cms-2026
#
# --- MySQL (Laragon) ---
# Salin api/config.local.php.example → api/config.local.php
# npm run db:sync          (buat DB + tabel + seed CMS)
# npm run db:sync:sqlite   (salin dari api/data/app.db jika ada)
# Database: alquran | User: root | Password: (kosong)
# Fallback SQLite: set DB_DRIVER=sqlite di config.local.php
# CMS API — wajib untuk Android (IP PC Laragon, bukan 127.0.0.1):
# VITE_CMS_API_BASE=http://192.168.1.10:8090/api/cms
# Materi kajian: GET /api/cms/public/learning.php
# Production (otomatis di npm run build): lihat .env.production
#   http://195.88.211.93:8087/api/cms
