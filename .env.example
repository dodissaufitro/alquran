# =============================================================================
# TALAQEE — Konfigurasi aplikasi
# Salin file ini ke .env lalu sesuaikan nilainya.
# =============================================================================

# --- Umum ---
# production = aktifkan proteksi demo & validasi password CMS lemah
# development = login/API santai di localhost; production = wajib token API
APP_ENV=development
APP_ORIGIN=https://app.talaqee.com
APP_NAME=Talaqee
APP_SERVICE_PREFIX=faithfulpath
# Production: set ke https://app.talaqee.com (jangan * jika memakai cookie sesi)
API_CORS_ORIGIN=*

# --- Database MySQL (Laragon default) ---
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=alquran
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Fallback SQLite (tanpa MySQL): DB_DRIVER=sqlite

# --- CMS Admin (panel /admin.html) ---
CMS_ADMIN_USER=app.talaqee.com
CMS_ADMIN_PASSWORD=Jakarta1945@@
CMS_SESSION_TTL_SECONDS=604800

# --- Google OAuth (backend PHP) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_PATH=/api/auth/google-app-callback.php
# GOOGLE_OAUTH_REDIRECT_URI=https://app.talaqee.com/api/auth/google-app-callback.php

# --- Google OAuth & app (frontend — wajib saat npm run build) ---
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_OAUTH_REDIRECT_URI=https://app.talaqee.com/api/auth/google-app-callback.php

# --- Android / Capacitor ---
ANDROID_PACKAGE=com.faithfulpath.alquran
VITE_ANDROID_PACKAGE=com.faithfulpath.alquran
VITE_APP_DEEP_LINK_SCHEME=com.faithfulpath.alquran

# --- Akun internal (login username/password) ---
INTERNAL_EMAIL_SUFFIX=@app.faithfulpath
VITE_INTERNAL_EMAIL_SUFFIX=@app.faithfulpath

# --- Origin & API frontend ---
# Dev web: kosongkan base API = proxy Vite (npm run dev + npm run api:php)
# APK / build production: WAJIB set ke domain server PHP Anda (bukan localhost/Laragon)
VITE_APP_ORIGIN=https://app.talaqee.com
VITE_CMS_API_BASE=
VITE_SUBSCRIPTION_API_BASE=
VITE_COINS_API_BASE=
VITE_TALAQQI_API_BASE=
VITE_AUTH_API_BASE=
VITE_TALAQQI_WS_URL=

# --- Dev server ---
PHP_DEV_SERVER_HOST=127.0.0.1
PHP_DEV_SERVER_PORT=8090
VITE_LARAGON_PROXY_TARGET=http://127.0.0.1:8090
VITE_TALAQQI_PROXY_TARGET=http://127.0.0.1:3847

# --- Talaqqi chat (Node) ---
TALAQQI_CHAT_PORT=3847
TALAQQI_CHAT_HOST=0.0.0.0
TALAQQI_CHAT_ROOM=talaqqi-fatihah
# Email guru/koreksi — pisahkan koma:
# VITE_TALAQQI_SUPER_ADMIN_EMAILS=anda@gmail.com

# --- Pembayaran jurnal & coin ---
SUBSCRIPTION_DEMO_SECRET=faithfulpath-jurnal-demo-2026
VITE_SUBSCRIPTION_DEMO_KEY=faithfulpath-jurnal-demo-2026
SUBSCRIPTION_PRICE_IDR=29000
SUBSCRIPTION_APP_ORIGIN=https://app.talaqee.com
SUBSCRIPTION_REDIRECT_BASE_URL=http://localhost:5173
SUBSCRIPTION_APK_RETURN_URL=https://app.talaqee.com/payment-return.html
SUBSCRIPTION_PERIOD_SECONDS=2592000
COIN_RECORDING_COST=5
COINS_PERIOD_SECONDS=31536000

# QR demo / Midtrans
QR_API_BASE_URL=https://api.qrserver.com/v1/create-qr-code/
QR_API_SIZE=300x300
QR_API_MARGIN=10
XENDIT_API_BASE=https://api.xendit.co
MIDTRANS_API_BASE_SANDBOX=https://api.sandbox.midtrans.com
MIDTRANS_API_BASE_PRODUCTION=https://api.midtrans.com

# --- Talaqqi API (PHP) ---
TALAQQI_MAX_AUDIO_BYTES=8388608
TALAQQI_UPLOAD_MAX_FILESIZE=16M
TALAQQI_POST_MAX_SIZE=16M

# Xendit (disarankan)
# XENDIT_SECRET_KEY=xnd_development_xxxxxxxx
# XENDIT_WEBHOOK_TOKEN=token_dari_dashboard_xendit

# Midtrans QRIS (opsional)
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
# MIDTRANS_IS_PRODUCTION=0

# --- Lainnya ---
# VITE_SUPPORT_WHATSAPP=6281234567890

# =============================================================================
# Panduan singkat
# =============================================================================
# 1. Salin: cp .env.example .env
# 2. Isi GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET + VITE_GOOGLE_CLIENT_ID
# 3. Dev: npm run api:php (terminal 1) + npm run dev (terminal 2)
# 4. Build production: npm run build (baca .env.production)
# 5. Semua API PHP membaca .env — tidak perlu api/config.local.php
#
# Google Console → Authorized JavaScript origins:
#   http://localhost:5173
#   http://127.0.0.1:5173
#   https://app.talaqee.com
#   https://localhost
#
# Authorized redirect URIs (Web client):
#   https://app.talaqee.com/api/auth/google-app-callback.php
#   com.faithfulpath.alquran://oauth (Android)
