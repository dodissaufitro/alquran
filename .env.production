# Build production + APK — npm run build / npm run cap:sync
# Public: https://app.talaqee.com/

VITE_CMS_API_BASE=https://app.talaqee.com/api/cms
VITE_SUBSCRIPTION_API_BASE=https://app.talaqee.com/api/subscription
VITE_TALAQQI_API_BASE=https://app.talaqee.com/api/talaqqi
VITE_TALAQQI_WS_URL=wss://app.talaqee.com/api/talaqqi/ws

# Wajib untuk login Google di APK — isi sebelum build:
# VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Google OAuth — Authorized JavaScript origins:
#   https://app.talaqee.com
#   https://localhost
#   http://localhost
# Redirect URI APK: com.faithfulpath.alquran://oauth
